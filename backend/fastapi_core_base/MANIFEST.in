# MANIFEST.in - Ensures non-Python files are included in the package distribution.
# Used in conjunction with 'include_package_data=True' in setup.py.

# Include the project metadata
include pyproject.toml
include uv.lock
include README.md
include .python-version

# Include all client configuration files
recursive-include config *.toml

# Environment template
include .env.example

# Include the shared services and source code
recursive-include src *.py
recursive-include src/shared/data *.parquet

# Security & QA
include .secrets.baseline
include .pre-commit-config.yaml
include .dockerignore
include pyproject.toml

# Build cleanup
global-exclude *.pyc
global-exclude __pycache__
global-exclude .DS_Store

# Exclude unnecessary local files
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude tests *
recursive-exclude data *
recursive-exclude duckdb_data *
recursive-exclude logs *
